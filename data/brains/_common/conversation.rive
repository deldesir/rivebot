// ═══════════════════════════════════════════════════════════════
//  Shared Conversation — included by all persona topics
//
//  Design philosophy:
//    • Talk like a real person, not a customer-service bot
//    • Not every message needs a reply — silence is ok
//    • Keep it short and natural
// ═══════════════════════════════════════════════════════════════

! local concat = newline

> topic conversation

  // ── Greetings (with onboarding gate) ───────────────────────
  + (bonjou|bonswa|salut|alo)
  * <get onboarded> == undefined => <set lang=ht>{topic=onboarding}Yo! Kijan yo rele w?
  * <get welcomed> == true => <set lang=ht>👋 <get name>! Kisa w bezwen?{weight=3}
  - <set lang=ht>👋 Bonjou! Kisa w bezwen?{weight=3}
  - <set lang=ht>Salut! Kijan m ka ede w?{weight=2}
  - <set lang=ht>Alo! 👋

  + (hello|hi|hey)
  * <get onboarded> == undefined => <set lang=en>{topic=onboarding}Hey! What's your name?
  * <get welcomed> == true => <set lang=en>👋 Hey <get name>! What's up?{weight=3}
  * <get lang> == ht => <set lang=ht>👋 Bonjou! Kisa w bezwen?
  - <set lang=en>Hey! 👋 What can I do for you?{weight=3}
  - <set lang=en>Hi! How can I help?{weight=2}
  - <set lang=en>Hello! 👋

  // ── How Are You ────────────────────────────────────────────
  + (koman ou ye|how are you|sa k ap fet|sa kap fet)
  * <get lang> == en => I'm good, thanks! 😊 You?
  - Mwen byen, mèsi! 😊 E ou menm?

  // ── Thanks — short and sweet ────────────────────────────────
  + (mesi|merci|thanks|thank) *
  * <get lang> == en => {random}No problem!|Happy to help!|Anytime! 👍{/random}
  - {random}Pa gen pwoblèm!|Avèk plezi!|Nenpòt lè! 👍{/random}

  + (mesi|merci|thanks|thank)
  * <get lang> == en => {random}You're welcome!|Sure thing! 👍|No worries!{/random}
  - {random}Avèk plezi!|Pa gen kwa! 👍|Dekwa!{/random}

  // ── Farewell — casual ──────────────────────────────────────
  + (orevwa|bye|goodbye|kenbe|babay|adye) *
  * <get lang> == en => See you! {random}👋|✌️{/random}
  - Kenbe! {random}👋|✌️{/random}

  + (orevwa|bye|goodbye|kenbe|babay|adye)
  * <get lang> == en => Bye! {random}👋|🙌{/random}
  - Babay! {random}👋|🙌{/random}

  // ── Sentiment Detection ────────────────────────────────────
  + [*] (@frustration) [*]
  * <get lang> == en => <set mood=frustrated>I hear you. 😔 Tell me what's going on and I'll try to help.
  - <set mood=frustrated>Mwen konprann. 😔 Di m kisa k ap pase epi m ap eseye ede w.

  + [*] (@positive) [*]
  * <get lang> == en => <set mood=happy>😊
  - <set mood=happy>😊

  // ── Persona Switching ────────────────────────────────────────
  // Simple direct triggers — no [*] optionals or @ redirects
  // which may not work correctly with this RiveScript fork.

  + talk to sales
  - <set switch_persona=konex-sales>{{persona_switch}}

  + talk to sales *
  - <set switch_persona=konex-sales>{{persona_switch}}

  + pale ak vant
  - <set switch_persona=konex-sales>{{persona_switch}}

  + pale ak vant *
  - <set switch_persona=konex-sales>{{persona_switch}}

  + talk to support
  - <set switch_persona=konex-support>{{persona_switch}}

  + talk to support *
  - <set switch_persona=konex-support>{{persona_switch}}

  + pale ak support
  - <set switch_persona=konex-support>{{persona_switch}}

  + pale ak teknik
  - <set switch_persona=konex-support>{{persona_switch}}

  + talk to talkprep
  - <set switch_persona=talkprep>{{persona_switch}}

  + talk to talkprep *
  - <set switch_persona=talkprep>{{persona_switch}}

  + pale ak talkprep
  - <set switch_persona=talkprep>{{persona_switch}}

  + talk to coach
  - <set switch_persona=talkprep>{{persona_switch}}

  + pale ak coach
  - <set switch_persona=talkprep>{{persona_switch}}

  + go back
  - <set switch_persona=assistant>{{persona_switch}}

  + retounen
  - <set switch_persona=assistant>{{persona_switch}}

  + back
  - <set switch_persona=assistant>{{persona_switch}}

  + talk to assistant
  - <set switch_persona=assistant>{{persona_switch}}

  + pale ak assistant
  - <set switch_persona=assistant>{{persona_switch}}

  // ── Capabilities ───────────────────────────────────────────
  + (what can you do|what ou ka do|kisa ou ka do)
  @ help

< topic
